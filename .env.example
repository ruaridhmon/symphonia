# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Symphonia — Environment Configuration                                  ║
# ║  Copy this file:  cp .env.example .env   then edit values below.        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────────
# These compose the DATABASE_URL automatically in docker-compose.yml.
# If you set DATABASE_URL explicitly it takes precedence in the backend.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=holdbacktherive
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:holdbacktherive@db:5432/postgres

# ── Auth / Security ──────────────────────────────────────────────────────
# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=your-jwt-secret-CHANGE-ME

# Admin account created on first startup
ADMIN_EMAIL=antreas@axiotic.ai
ADMIN_PASSWORD=test123

# Cookie security (set to "false" for local HTTP without TLS)
COOKIE_SECURE=false

# ── AI / Synthesis ───────────────────────────────────────────────────────
# OpenRouter API key — required for ALL non-mock synthesis modes.
# Get one at https://openrouter.ai/keys
# Leave empty to use mock mode automatically.
OPENROUTER_API_KEY=

# Synthesis mode — controls which synthesis strategy is used:
#   mock      → Placeholder text, no API calls (default, free)
#   simple    → Single-prompt LLM synthesis via OpenRouter
#   committee → Multi-agent committee (falls back to TTD internally)
#   ttd       → Iterative diffusion-based synthesis (recommended for quality)
# When OPENROUTER_API_KEY is empty, mock mode is used regardless of this setting.
SYNTHESIS_MODE=mock

# Default synthesis model (OpenRouter model ID, overridable per-request in the UI)
SYNTHESIS_MODEL=anthropic/claude-opus-4-6

# Synthesis timeout in seconds (per synthesis run)
# SYNTHESIS_TIMEOUT=600

# Optional: path to custom consensus prompt templates
# CONSENSUS_PROMPTS_DIR=

# Send email notifications when synthesis completes? (true/false)
NOTIFY_ON_SYNTHESIS=true

# ── Rate Limiting ────────────────────────────────────────────────────────
# Rate limiting is enabled by default. Set to "false" to disable.
RATE_LIMIT_ENABLED=true

# ── Email (SMTP) ─────────────────────────────────────────────────────────
# Required only for invitation / notification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=info@colabintel.org

# ── Frontend ─────────────────────────────────────────────────────────────
# Base URL the frontend uses to reach the backend API.
# In Docker (production): leave empty — nginx proxies /api/* to the backend.
# In dev mode: set to http://localhost:8000 so Vite's dev server can reach it.
VITE_API_BASE_URL=

# ── Docker Compose Ports ─────────────────────────────────────────────────
# Change these if you have port conflicts on your host.
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5432
