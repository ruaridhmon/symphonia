# Backend-only .env (for running outside Docker)
# For Docker usage, see the root .env.example instead.

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
JWT_SECRET=your-jwt-secret-CHANGE-ME
COOKIE_SECURE=false

# Leave empty for SQLite fallback, or set for Postgres
# DATABASE_URL=postgresql://postgres:holdbacktherive@localhost:5432/postgres

OPENROUTER_API_KEY=
SYNTHESIS_MODE=mock
